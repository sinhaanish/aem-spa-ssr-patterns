{
  "name": "mysite",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--openssl-legacy-provider react-scripts start",
    "build": "cross-env NODE_OPTIONS=--openssl-legacy-provider react-scripts build && clientlib --verbose",
    "build-with-ssr": "cross-env NODE_OPTIONS=--openssl-legacy-provider react-scripts build && cross-env NODE_OPTIONS=--openssl-legacy-provider webpack --config webpack.config.adobeio.js && clientlib --verbose",
    "build-with-express": "cross-env NODE_OPTIONS=--openssl-legacy-provider react-scripts build && cross-env NODE_OPTIONS=--openssl-legacy-provider webpack --config webpack.config.express.js && clientlib --verbose",
    "build-with-edge": "cross-env NODE_OPTIONS=--openssl-legacy-provider react-scripts build && cross-env NODE_OPTIONS=--openssl-legacy-provider webpack --config webpack.config.edge.js && clientlib --verbose",
    "build-edge-only": "cross-env NODE_OPTIONS=--openssl-legacy-provider webpack --config webpack.config.edge.js",
    "start-ssr-edge-local": "cross-env NODE_PATH=./node_modules node ../edge-functions/ssr/local-dev-server.js",
    "start-ssr-ioruntime": "cross-env NODE_ENV=development aio app run --local",
    "start-ssr-express": "node dist/express.js",
    "deploy-ssr-ioruntime": "cross-env NODE_ENV=production aio app deploy",
    "test": "cross-env NODE_OPTIONS=--openssl-legacy-provider react-scripts test",
    "eject": "react-scripts eject",
    "sync": "aemsync -d -w ../ui.apps/src/main/content"
  },
  "dependencies": {
    "@adobe/aem-core-components-react-base": "^1.1.8",
    "@adobe/aem-core-components-react-spa": "^1.2.0",
    "@adobe/aem-react-editable-components": "^1.1.6",
    "@adobe/aem-spa-component-mapping": "^1.1.1",
    "@adobe/aem-spa-page-model-manager": "^1.3.11",
    "@adobe/aio-sdk": "^3.0.0",
    "custom-event-polyfill": "^1.0.7",
    "history": "^4.10.1",
    "minimist": "^1.2.0",
    "node-fetch": "^2.6.0",
    "pako": "^2.0.4",
    "react": "^16.12.0",
    "react-app-polyfill": "^1.0.5",
    "react-dom": "^16.12.0",
    "react-fast-compare": "^3.0.1",
    "react-router": "^5.1.2",
    "react-router-dom": "^5.1.2",
    "react-universal-component": "^4.5.0",
    "regenerator-runtime": "^0.13.7",
    "sanitize-html": "^2.3.3"
  },
  "devDependencies": {
    "@adobe/aio-cli": "^8.2.0",
    "@openwhisk/wskdebug": "^1.3.0",
    "@testing-library/jest-dom": "^4.2.4",
    "@testing-library/react": "^9.3.2",
    "@testing-library/user-event": "^7.1.2",
    "aem-clientlib-generator": "^1.5.0",
    "aemsync": "^4.0.0",
    "ajv": "^6.10.0",
    "babel-core": "^6.26.2",
    "babel-plugin-universal-import": "^4.0.0",
    "babel-polyfill": "^6.26.0",
    "babel-preset-es2015": "^6.24.1",
    "buffer": "^6.0.3",
    "clean-webpack-plugin": "^0.1.19",
    "clone": "^2.1.2",
    "cross-env": "^7.0.3",
    "css-loader": "^3.4.2",
    "enzyme": "^3.10.0",
    "enzyme-adapter-react-16": "^1.15.1",
    "ignore-styles": "^5.0.1",
    "null-loader": "^4.0.1",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "react-scripts": "4.0.3",
    "sass-loader": "^6.0.7",
    "sinon": "^7.5.0",
    "stream-browserify": "^3.0.0",
    "style-loader": "^0.20.3",
    "typescript": "^3.4.2",
    "util": "^0.12.5",
    "webpack": "4.44.2",
    "webpack-cli": "^3.0.8",
    "webpack-dev-server": "3.11.1",
    "webpack-node-externals": "^1.7.2",
    "webpack-shell-plugin": "^0.5.0"
  },
  "proxy": "http://localhost:4502",
  "browserslist": [
    "defaults"
  ],
  "eslintConfig": {
    "extends": "react-app"
  }
}
